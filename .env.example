# ==== Telegram ====
# Create a bot via @BotFather in Telegram: /newbot
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to talk to the bot.
# Get your ID from @userinfobot. Leave empty to lock the bot down (no one allowed).
TELEGRAM_ALLOWED_USER_IDS=

# ==== Claude ====
# Either an Anthropic API key OR a logged-in claude CLI auth (see SETUP.md).
ANTHROPIC_API_KEY=

# Model (optional, default is sonnet). Override for Opus etc.
CLAUDE_MODEL=claude-sonnet-4-5

# ==== Cloudflare (only needed from control machine to bootstrap DNS + origin cert) ====
CF_API_TOKEN=
CF_ZONE=biswas.me
CLAW_HOSTNAME=claw.biswas.me

# ==== Deployment target ====
CLAW_HOST=
CLAW_SSH_USER=ubuntu
