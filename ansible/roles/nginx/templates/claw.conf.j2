# Managed by ansible — openclaw
# Cloudflare sits in front; nginx just terminates traffic from CF and proxies
# everything to the openclaw Go binary on 127.0.0.1:8080. The app handles
# authentication itself (cookie-based login, see dashboard.go).

{% set cf_ranges = [
  '173.245.48.0/20', '103.21.244.0/22', '103.22.200.0/22', '103.31.4.0/22',
  '141.101.64.0/18', '108.162.192.0/18', '190.93.240.0/20', '188.114.96.0/20',
  '197.234.240.0/22', '198.41.128.0/17', '162.158.0.0/15', '104.16.0.0/13',
  '104.24.0.0/14', '172.64.0.0/13', '131.0.72.0/22',
] %}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name {{ claw_hostname }} _;

    {% for r in cf_ranges %}set_real_ip_from {{ r }};
    {% endfor %}real_ip_header CF-Connecting-IP;

    location = /health {
        default_type text/plain;
        return 200 "ok\n";
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ claw_hostname }};

    ssl_certificate     {{ nginx_cert_path }};
    ssl_certificate_key {{ nginx_key_path }};

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;

    {% for r in cf_ranges %}set_real_ip_from {{ r }};
    {% endfor %}real_ip_header CF-Connecting-IP;

    location = /health {
        default_type text/plain;
        return 200 "ok\n";
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}
