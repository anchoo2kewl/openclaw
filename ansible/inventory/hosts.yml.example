all:
  hosts:
    openclaw:
      ansible_host: CHANGE_ME_IP
      ansible_user: ubuntu
      ansible_ssh_private_key_file: ~/.ssh/id_ed25519
      ansible_python_interpreter: /usr/bin/python3
  vars:
    claw_hostname: claw.biswas.me
    claw_install_dir: /opt/openclaw
    claw_workspace_dir: /opt/openclaw/workspace
    claw_repo_url: https://github.com/anchoo2kewl/openclaw.git
    claw_repo_ref: main
